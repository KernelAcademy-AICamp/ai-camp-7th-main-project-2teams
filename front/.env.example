# 공개 가능 — 클라이언트 번들 포함 허용
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 서버 전용 — NEXT_PUBLIC_ 접두어 절대 금지
# 클라이언트 컴포넌트·브라우저 번들·extension 코드에서 참조 금지
SUPABASE_SERVICE_ROLE_KEY=eyJ...
OPENAI_API_KEY=sk-...
YOUTUBE_API_KEY=AIza...

# /admin 대시보드 — 관리자 판별은 admin_users 테이블(마이그레이션 0027) 기반, env var 없음
# OpenAI Organization Usage/Costs API용 admin 키 (서버 전용, OPENAI_API_KEY와 별개)
OPENAI_ADMIN_KEY=
