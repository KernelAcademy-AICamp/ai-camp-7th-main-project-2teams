# 공개 가능 — 클라이언트 번들 포함 허용
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 서버 전용 — NEXT_PUBLIC_ 접두어 절대 금지
# 클라이언트 컴포넌트·브라우저 번들·extension 코드에서 참조 금지
SUPABASE_SERVICE_ROLE_KEY=eyJ...
OPENAI_API_KEY=sk-...          # 태그 분류(generateTags) 전용
# 임베딩 — bge-m3 (NVIDIA 엔드포인트 integrate.api.nvidia.com, 1024차원). A51/마이그레이션 0005
BGE_API_KEY=nvapi-...

# 벡터 검색 유사도 임계값 (기본 0.3 — 낮을수록 recall↑ precision↓)
# bge-m3 query/passage 비대칭 임베딩 — 모델 교체 후 운영 데이터로 recall@k 재튜닝 권장 (0.2~0.5 범위)
SEARCH_MATCH_THRESHOLD=0.3
